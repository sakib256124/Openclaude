{
  "name": "opencloud-compute-console",
  "version": "0.1.0",
  "private": true,
  "description": "OpenCloud Compute Console: an EC2-inspired virtual machine management dashboard using OpenStack APIs.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
