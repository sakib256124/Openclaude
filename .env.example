# Application
NODE_ENV=development
APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-strong-random-secret
SESSION_TIMEOUT_MINUTES=60

# Database
DATABASE_URL=postgresql://opencloud:opencloud_dev_password@localhost:5432/opencloud?schema=public

# Credential encryption
# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Multipass defaults. Host access settings are stored encrypted in PostgreSQL.
MULTIPASS_DEFAULT_HOST=localhost
MULTIPASS_DEFAULT_DRIVER=qemu
MULTIPASS_BIN=multipass
MULTIPASS_DEFAULT_IMAGE=24.04
MULTIPASS_DEFAULT_CPUS=1
MULTIPASS_DEFAULT_MEMORY=2G
MULTIPASS_DEFAULT_DISK=10G
MULTIPASS_SOCKET_PATH=
MULTIPASS_REQUEST_TIMEOUT_MS=30000
MULTIPASS_LAUNCH_TIMEOUT_MS=180000

# Optional bootstrap admin for local development only.
SEED_ADMIN_EMAIL=sakib09@gmail.com
SEED_ADMIN_NAME=Sakib
SEED_ADMIN_PASSWORD=111111

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
