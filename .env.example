# Application
NODE_ENV=development
APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-strong-random-secret
SESSION_TIMEOUT_MINUTES=60

# Database
DATABASE_URL=postgresql://opencloud:opencloud_dev_password@localhost:5432/opencloud?schema=public

# Credential encryption
# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# OpenStack defaults. Per-user connections are stored encrypted in PostgreSQL.
OPENSTACK_DEFAULT_AUTH_URL=https://openstack.example.com:5000/v3
OPENSTACK_DEFAULT_REGION=RegionOne
OPENSTACK_DEFAULT_INTERFACE=public
OPENSTACK_TLS_VERIFY=true
OPENSTACK_REQUEST_TIMEOUT_MS=30000

# Optional bootstrap admin for local development only.
SEED_ADMIN_EMAIL=sakib09@gmail.com
SEED_ADMIN_NAME=Sakib
SEED_ADMIN_PASSWORD=111111

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
